NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/secure-vault

# Redis
REDIS_URL=redis://localhost:6379

# JWT (use RS256 in production)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# For RS256: base64-encoded PEM keys
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# Password hashing
BCRYPT_ROUNDS=12
PASSWORD_ALGO=bcrypt

# MFA
MFA_ISSUER=SecureVault
MFA_BACKUP_ENCRYPTION_KEY=32-character-key-change-in-prod!

# Password Reset
RESET_TOKEN_SECRET=reset-secret-change-in-production
RESET_TOKEN_TTL_MINUTES=15

# CSRF
CSRF_SECRET=csrf-secret-change-in-production

# Signed Links
SIGNED_LINK_SECRET=link-secret-change-in-production
SIGNED_LINK_DEFAULT_TTL=3600

# Frontend
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
