{
  "name": "securevault-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":     "vite",
    "build":   "vite build",
    "preview": "vite preview",
    "test":    "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios":        "^1.7.2",
    "dompurify":    "^3.1.5",
    "react":        "^18.3.1",
    "react-dom":    "^18.3.1",
    "react-router-dom": "^6.24.0",
    "zxcvbn":       "^4.4.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom":  "^6.4.6",
    "@testing-library/react":     "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/dompurify":           "^3.0.5",
    "@vitejs/plugin-react":       "^4.3.1",
    "jsdom":                      "^24.1.0",
    "vite":                       "^5.3.2",
    "vite-plugin-sri3":           "^1.0.3",
    "vitest":                     "^1.6.0"
  },
  "vitest": {
    "environment": "jsdom",
    "globals": true,
    "setupFiles": ["./src/__tests__/setup.js"]
  }
}