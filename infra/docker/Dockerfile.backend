FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production

FROM node:20-alpine
WORKDIR /app
RUN addgroup -S vault && adduser -S vault -G vault
COPY --from=builder /app/node_modules ./node_modules
COPY . .
RUN chown -R vault:vault /app
USER vault
EXPOSE 5000
CMD ["node", "server.js"]
